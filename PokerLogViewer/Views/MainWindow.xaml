<Window x:Class="PokerLogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Poker Log Viewer"
        Height="600"
        Width="1000">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- TOP PANEL (controls) -->
        <!-- ========================= -->

        <Grid Grid.Row="0"
      Grid.ColumnSpan="3"
      Margin="0,0,0,10"
      MinHeight="40"
      VerticalAlignment="Center">

            <!-- ЕДИНЫЕ СТИЛИ -->
            <Grid.Resources>

                <Style TargetType="TextBox">
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                </Style>

                <Style TargetType="Button">
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                </Style>

            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH -->
            <TextBox Grid.Column="0"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- PATH -->
            <TextBox Grid.Column="1"
             Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="2"
                Content="{Binding SelectFolderText}"
                Command="{Binding SelectFolderCommand}"
                Width="90"
                Height="32"/>

            <Button Grid.Column="3"
                Content="{Binding StartScanText}"
                Command="{Binding StartScanCommand}"
                Width="110"
                Height="32"/>

            <!-- RU -->
            <Button Grid.Column="4"
            Content="RU"
            Command="{Binding SetRuCommand}"
            Width="32"
            Height="32"
            VerticalContentAlignment="Center"/>

            <!-- EN -->
            <Button Grid.Column="5"
            Content="EN"
            Command="{Binding SetEnCommand}"
            Width="32"
            Height="32"
            VerticalContentAlignment="Center"/>

            <!-- STATUS -->
            <Border Grid.Column="6"
            Height="32"
            VerticalAlignment="Center"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="6"
            Margin="10,0,0,0">

                <TextBlock Text="{Binding Status}"
                   VerticalAlignment="Center"/>
            </Border>

        </Grid>

        <!-- ========================= -->
        <!-- LEFT: TABLES -->
        <!-- ========================= -->
        <GroupBox Header="Tables" Grid.Row="1" Grid.Column="0" Margin="5">
            <ListBox ItemsSource="{Binding Tables}"
                     SelectedItem="{Binding SelectedTable}"
                     />
        </GroupBox>

        <!-- ========================= -->
        <!-- CENTER: HAND IDS -->
        <!-- ========================= -->
        <GroupBox Header="Hand IDs" Grid.Row="1" Grid.Column="1" Margin="5">
            <ListBox ItemsSource="{Binding HandIds}"
                     SelectedItem="{Binding SelectedHand}"/>
        </GroupBox>

        <!-- ========================= -->
        <!-- RIGHT: DETAILS -->
        <!-- ========================= -->
        <GroupBox Header="Details" Grid.Row="1" Grid.Column="2" Margin="5">
            <TextBlock Text="{Binding Details}"
                       TextWrapping="Wrap"
                       Padding="10"/>
        </GroupBox>

    </Grid>
</Window>